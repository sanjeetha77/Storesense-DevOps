# ============================================================
# AI Store Representation Optimizer — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Shopify ---
# Private/Custom App access token for your Shopify store.
# Required scopes: read_products, read_policies (for policy signals)
# Generate at: Shopify Admin → Settings → Apps → Develop apps
SHOPIFY_ACCESS_TOKEN=""

SHOPIFY_API_VERSION=2024-01

GEMINI_API_KEY=""
